@article{silvaRustLikeBorrowChecker2024,
  title = {Towards a {{Rust-Like Borrow Checker}} for {{C}}},
  author = {Silva, Tiago and Correia, Pedro Gonçalo and Sousa, Luís and Bispo, João and Carvalho, Tiago},
  date = {2024-10-29},
  journaltitle = {ACM Transactions on Embedded Computing Systems},
  shortjournal = {ACM Trans. Embed. Comput. Syst.},
  pages = {3702229},
  issn = {1539-9087, 1558-3465},
  doi = {10.1145/3702229},
  url = {https://dl.acm.org/doi/10.1145/3702229},
  urldate = {2024-12-20},
  abstract = {Memory safety issues in C are the origin of various vulnerabilities that can compromise a program’s correctness or safety from attacks. We propose an approach to tackle memory safety by replicating Rust’s Mid-level Intermediate Representation (MIR) Borrow Checker. Our solution uses static analysis and successive source-to-source code transformations to be composed upstream of the compiler, ensuring maximal compatibility with existing build systems. This allows us to apply the memory safety guarantees of the rustc compiler to C code with fewer changes than a rewrite in Rust. In this work, we present a comprehensive study of Rust’s eforts towards ensuring memory safety, and describe the theoretical basis for a C borrow checker, alongside a proof-of-concept that was developed to demonstrate its potential. We have evaluated the prototype on the CHStone and bzip2 benchmarks. This prototype correctly identiied violations of the ownership and aliasing rules, and exposed incompatibilities between such rules and common C patterns, which can be addressed in future work. CCS Concepts: · Software and its engineering → Software safety; Preprocessors; Allocation / deallocation strategies.},
  langid = {english},
  file = {/home/filip/Zotero/storage/FFAT9KEA/Silva et al. - 2024 - Towards a Rust-Like Borrow Checker for C.pdf}
}

